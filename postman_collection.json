    {
      "name": "Registro de usuario",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const ts = Date.now();",
              "pm.environment.set('test_username', 'testuser_' + ts);",
              "pm.environment.set('test_email', 'test_' + ts + '@ecorun.com');",
              "pm.environment.set('test_password', 'Test123');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Devuelve token JWT\", function() {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('token');",
              "    pm.expect(json.token).to.be.a('string').and.not.empty;",
              "    pm.environment.set('auth_token', json.token);",
              "});",
              "pm.test(\"Devuelve datos del usuario\", function() {",
              "    const json = pm.response.json();",
              "    pm.expect(json.user).to.have.property('id');",
              "    pm.expect(json.user).to.have.property('username');",
              "    pm.expect(json.user).to.have.property('email');",
              "    pm.environment.set('user_id', json.user.id);",
              "});",
              "pm.test(\"No expone password_hash\", function() {",
              "    const json = pm.response.json();",
              "    pm.expect(json.user).to.not.have.property('password_hash');",
              "    pm.expect(json.user).to.not.have.property('password');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
