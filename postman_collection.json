    {
      "name": "Crear carrera",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const now = new Date();",
              "const end = new Date(now.getTime() + 30 * 60000);",
              "pm.environment.set('run_start_time', now.toISOString());",
              "pm.environment.set('run_end_time', end.toISOString());",
              "pm.environment.set('run_date', now.toISOString().split('T')[0]);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201\", function() {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Run creado con campos correctos\", function() {",
              "    const json = pm.response.json();",
              "    pm.expect(json.success).to.be.true;",
              "    pm.expect(json.data).to.have.property('id');",
              "    pm.expect(json.data).to.have.property('run_name');",
              "    pm.expect(json.data).to.have.property('distance_km');",
              "    pm.expect(json.data).to.have.property('points_earned');",
              "    pm.environment.set('run_id', json.data.id);",
              "});",
              "pm.test(\"Puntos calculados automaticamente\", function() {",
              "    pm.expect(pm.response.json().data.points_earned).to.equal(50);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{auth_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": {{user_id}},\n  \"run_name\": \"Carrera Test Sevilla\",\n  \"description\": \"Carrera de prueba generada por Postman\",\n  \"distance_km\": 5,\n  \"duration_minutes\": 30,\n  \"start_time\": \"{{run_start_time}}\",\n  \"end_time\": \"{{run_end_time}}\",\n  \"run_date\": \"{{run_date}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": { "raw": "http://localhost:8080/api/runs", "host": ["http://localhost:8080"], "path": ["api", "runs"] }
