PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# DB_TYPE: 'mssql' para SQL Server (local), 'mysql' para MySQL (Railway/producción)
DB_TYPE=mssql

# --- SQL Server Express (local) ---
DB_HOST=localhost\sqlexpress01
DB_USER=ecorun_app
DB_PASSWORD=your_password
DB_NAME=ecorun_sevilla
DB_PORT=1433

# --- MySQL Railway (producción) ---
# DB_HOST=<host de Railway>
# DB_USER=<usuario de Railway>
# DB_PASSWORD=<password de Railway>
# DB_NAME=ecorun_sevilla
# DB_PORT=3306

JWT_SECRET=cambia_esto_por_un_secreto_seguro
